data/silver/
data/previews-veritical/
data/exports/

# ignore all preview GIFs except the 3 committed demo files
data/previews/*
!data/previews/214dfc443104674a.gif
!data/previews/2d84b1ab55ab81d3.gif
!data/previews/32275d7231509117.gif

# ignore all parquet except committed gold metrics
*.parquet
!data/gold/scenario_metrics.parquet
!data/gold/interaction_metrics.parquet
!data/gold/risk_metrics.parquet
!data/gold/comfort_metrics.parquet

